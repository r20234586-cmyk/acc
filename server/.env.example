# Database Configuration
# PostgreSQL database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ActivityCrew-Final
DB_USER=postgres
DB_PASSWORD=password

# Server Configuration
# Port where the server will listen
PORT=5000
# Environment mode (development/production)
NODE_ENV=development

# CORS Configuration
# Allowed origin for cross-origin requests (should match your frontend URL)
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
# IMPORTANT: Generate strong random strings in production!
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_this_in_production

# JWT Token Expiry Times
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Service Configuration (Optional - for production use)
# Using Sendgrid, Nodemailer, or similar
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@activitycrew.com

# Security Configuration
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
